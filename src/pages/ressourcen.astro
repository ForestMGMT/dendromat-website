---

<BaseLayout
  title="Ressourcen — Dendromat"
  description="Kuratierte Linksammlung forstlicher Ressourcen: Behörden, Verbände, Ausbildung, GIS und Fachmedien."
>
  <NavBar />

  <main class="ressourcen-page container">
    <header class="page-header">
      <h1 class="page-title">Linksammlung</h1>
      <p class="page-subtitle">Kuratierte Ressourcen für den Schweizer Forstbereich</p>
    </header>

    {CATEGORIES.map(cat => (
      <section class="category" id={cat.id}>
        <h2 class="category__title">
          <span class="category__emoji">{cat.emoji}</span>
          {cat.title}
        </h2>
        <div class="link-grid">
          {cat.links.map(link => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="link-card"
            >
              <div class="link-card__body">
                <span class="link-card__title">{link.title}</span>
                {link.subtitle && (
                  <span class="link-card__subtitle">{link.subtitle}</span>
                )}
                <span class="link-card__desc">{link.desc}</span>
              </div>
              <span class="link-card__url">{link.display} ↗</span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </main>

  <Footer />
</BaseLayout>

<style>
  .ressourcen-page {
    padding-top: 3rem;
    padding-bottom: 4rem;
    max-width: 1100px;
  }

  /* ── Page header ─────────────────────────────────── */
  .page-header {
    margin-bottom: 3rem;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    color: var(--clr-green-dark);
    margin: 0 0 0.4rem;
  }

  .page-subtitle {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--clr-text-muted, #666);
    margin: 0;
  }

  /* ── Category section ────────────────────────────── */
  .category {
    margin-bottom: 3rem;
  }

  .category__title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--clr-green-dark);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--clr-green-light, #a8cc80);
  }

  .category__emoji {
    font-size: 1.1rem;
  }

  /* ── Link card grid ──────────────────────────────── */
  .link-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .link-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1rem 1.1rem;
    background: #fff;
    border: 1px solid #e0e8d8;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s, border-color 0.15s, transform 0.15s;
  }

  .link-card:hover {
    box-shadow: 0 4px 16px rgba(42, 92, 40, 0.12);
    border-color: var(--clr-green-light, #a8cc80);
    transform: translateY(-2px);
  }

  .link-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .link-card__title {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--clr-green-dark);
  }

  .link-card__subtitle {
    font-size: 0.78rem;
    color: #666;
    font-style: italic;
  }

  .link-card__desc {
    font-size: 0.82rem;
    color: #444;
    line-height: 1.45;
    margin-top: 0.3rem;
  }

  .link-card__url {
    font-size: 0.75rem;
    font-family: var(--font-sans);
    color: var(--clr-green-mid, #3a7a38);
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  @media (max-width: 600px) {
    .link-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
