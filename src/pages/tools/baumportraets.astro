};

/* ── Scale / trait definitions ───────────────────────────── */
var SCALE_KEYS  = ['sehr klein','klein','mittel','gross','sehr gross'];
var SCALE_TKEYS = ['scaleVerySmall','scaleSmall','scaleMedium','scaleLarge','scaleVeryLarge'];

var PHYSIO_ROWS = [
  {key:'Schattentoleranz',        tKey:'physioSchatten'},
  {key:'Schattenerzeugung',       tKey:'physioSchattenerzeugung'},
  {key:'Kaeltetoleranz',          tKey:'physioKaelte',     dataKey:'K\u00e4ltetoleranz'},
  {key:'Sp\u00e4tfrosttoleranz',  tKey:'physioSpaetfrost'},
  {key:'Trockenheitstoleranz',    tKey:'physioTrocken'},
  {key:'N\u00e4ssetoleranz',      tKey:'physioNaesse'},
  {key:'N\u00e4hrstoffarmutstoleranz', tKey:'physioNaehrstoff'},
  {key:'Streuabbaubarkeit',       tKey:'physioStreu'},
];
var EINFL_ROWS = [
  {key:'Einfluss Wild',       tKey:'einflWild'},
  {key:'Einfluss Sch\u00e4dlinge', tKey:'einflSchaedlinge'},
  {key:'Einfluss N\u00fctzlinge',  tKey:'einflNuetzlinge'},
];

/* ── Language state ──────────────────────────────────────── */
var bpLang = localStorage.getItem('dendromat-lang') || 'de';
if (!BP_UI[bpLang]) bpLang = 'de';

function bpt(key) {
  return (BP_UI[bpLang] || BP_UI.de)[key] || BP_UI.de[key] || key;
}

/* ── DOM refs ────────────────────────────────────────────── */
var sel   = document.getElementById('sp-sel');
var port  = document.getElementById('portrait');
var empty = document.getElementById('bp-empty');

/* ── Helpers ─────────────────────────────────────────────── */
function bpEsc(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function getLangName(sp) {
  var tax = sp.taxonomie || {};
  if (bpLang === 'fr') return tax['Name Franz\u00f6sisch'] || sp.german;
  if (bpLang === 'en') return tax['Name Englisch']         || sp.german;
  if (bpLang === 'it') return tax['Name Italienisch']      || sp.german;
  return sp.german;
}

function translateKey(k) {
  if (bpLang === 'de') return k;
  return (DATA_TRANSLATIONS.keys[bpLang] || {})[k] || k;
}

function translateValue(v) {
  if (bpLang === 'de') return v;
  var direct = (DATA_TRANSLATIONS.values[bpLang] || {})[v];
  if (direct !== undefined) return direct;
  var result = String(v);
  var subs = DATA_TRANSLATIONS.wordSubs[bpLang] || [];
  for (var i = 0; i < subs.length; i++) {
    result = result.split(subs[i][0]).join(subs[i][1]);
  }
  return result;
}

/* ── Dropdown ────────────────────────────────────────────── */
function populateDropdown() {
  var currentVal = sel.value;
  sel.innerHTML = '<option value="">' + bpt('selectPlaceholder') + '</option>';
  var species = Object.values(SPECIES_DATA).sort(function(a,b) {
    return getLangName(a).localeCompare(getLangName(b), bpLang);
  });
  species.forEach(function(sp) {
    var o = document.createElement('option');
    o.value = sp.latin;
    o.textContent = getLangName(sp) + ' \u2013 ' + sp.latin;
    sel.appendChild(o);
  });
  sel.value = currentVal;
}

/* ── Data table ──────────────────────────────────────────── */
function kvTable(obj) {
  if (!obj || !Object.keys(obj).length)
    return '<p class="bp-no-data">' + bpt('noData') + '</p>';
  var rows = Object.entries(obj).map(function(entry) {
    return '<tr><td>' + bpEsc(translateKey(entry[0])) + '</td><td>' + bpEsc(translateValue(String(entry[1]))) + '</td></tr>';
  }).join('');
  return '<table class="bp-data-table">' + rows + '</table>';
}

/* ── Taxonomy ────────────────────────────────────────────── */
function renderTaxonomie(tx) {
  var nameDe = tx['Name Deutsch']         || '';
  var nameFr = tx['Name Franz\u00f6sisch']|| '';
  var nameIt = tx['Name Italienisch']     || '';
  var nameEn = tx['Name Englisch']        || '';
  var opts = [
    nameDe ? '<option value="' + bpEsc(nameDe) + '">\uD83C\uDDE9\uD83C\uDDEA ' + bpEsc(nameDe) + '</option>' : '',
    nameFr ? '<option value="' + bpEsc(nameFr) + '">\uD83C\uDDEB\uD83C\uDDF7 ' + bpEsc(nameFr) + '</option>' : '',
    nameIt ? '<option value="' + bpEsc(nameIt) + '">\uD83C\uDDEE\uD83C\uDDF9 ' + bpEsc(nameIt) + '</option>' : '',
    nameEn ? '<option value="' + bpEsc(nameEn) + '">\uD83C\uDDEC\uD83C\uDDE7 ' + bpEsc(nameEn) + '</option>' : '',
  ].join('');

  var html = '<div class="bp-tax-names">'
    + '<div class="bp-tax-item"><label>' + bpt('taxLatein') + '</label><span class="bp-tax-val bp-tax-val--latin">' + bpEsc(tx['Taxon']||'') + '</span></div>'
    + '<div class="bp-tax-item"><label>' + bpt('taxName') + '</label><select class="bp-lang-sel">' + opts + '</select></div>'
    + '</div>';

  var rows1 = [];
  if (tx['Synonym Deutsch']) rows1.push('<tr><td>' + bpt('taxSynonymDe') + '</td><td>' + bpEsc(tx['Synonym Deutsch']) + '</td></tr>');
  if (tx['K\u00fcrzel'])     rows1.push('<tr><td>' + bpt('taxKuerzel')   + '</td><td>' + bpEsc(tx['K\u00fcrzel'])   + '</td></tr>');
  if (rows1.length) html += '<table class="bp-data-table">' + rows1.join('') + '</table>';

  html += '<hr class="bp-tax-divider">';

  var rows2 = [];
  if (tx['Abteilung'])   rows2.push('<tr><td>' + bpt('taxAbteilung')   + '</td><td>' + bpEsc(tx['Abteilung'])   + '</td></tr>');
  if (tx['Unterklasse']) rows2.push('<tr><td>' + bpt('taxUnterklasse') + '</td><td>' + bpEsc(tx['Unterklasse']) + '</td></tr>');
  if (tx['Ordnung'])     rows2.push('<tr><td>' + bpt('taxOrdnung')     + '</td><td>' + bpEsc(tx['Ordnung'])     + '</td></tr>');
  if (tx['Familie'])     rows2.push('<tr><td>' + bpt('taxFamilie')     + '</td><td>' + bpEsc(tx['Familie'])     + '</td></tr>');
  if (tx['Gattung'])     rows2.push('<tr><td>' + bpt('taxGattung')     + '</td><td>' + bpEsc(tx['Gattung'])     + '</td></tr>');
  if (tx['Taxon'])       rows2.push('<tr><td>' + bpt('taxArt')         + '</td><td><em>' + bpEsc(tx['Taxon']) + '</em></td></tr>');
  if (rows2.length) html += '<table class="bp-data-table">' + rows2.join('') + '</table>';

  return html;
}

/* ── Visual traits scale (replaces table) ───────────────── */
function traitDots(val) {
  var idx = SCALE_KEYS.indexOf(val);
  return SCALE_KEYS.map(function(s, i) {
    return '<span class="bp-dot' + (i === idx ? ' bp-dot--active' : '') + '"></span>';
  }).join('');
}

function traitsViz(sp) {
  var vals = Object.assign({}, sp.physio_values || {}, sp.einfluss_values || {});

  function makeRows(list) {
    return list.map(function(row) {
      /* support both umlaut key and escaped key */
      var val = vals[row.key] || (row.dataKey ? vals[row.dataKey] : undefined);
      var scaleIdx = val ? SCALE_KEYS.indexOf(val) : -1;
      var valLabel = scaleIdx >= 0 ? bpt(SCALE_TKEYS[scaleIdx]) : (val || '–');
      return '<div class="bp-trait-row">'
        + '<span class="bp-trait-label">' + bpEsc(bpt(row.tKey)) + '</span>'
        + '<span class="bp-trait-dots">' + traitDots(val) + '</span>'
        + '<span class="bp-trait-val">' + bpEsc(valLabel) + '</span>'
        + '</div>';
    }).join('');
  }

  var scaleLabels = SCALE_TKEYS.map(function(tk) {
    return '<span>' + bpEsc(bpt(tk)) + '</span>';
  }).join('');

  return '<div class="bp-traits">'
    + '<div class="bp-trait-scale-header"><span></span>' + scaleLabels + '<span></span></div>'
    + makeRows(PHYSIO_ROWS)
    + '<div class="bp-trait-sep"></div>'
    + makeRows(EINFL_ROWS)
    + '</div>';
}

/* ── Distribution + ecogram image tiles ─────────────────── */
function imgBlock(slug, oekoLabel) {
  var v = '/baumportraets/images/' + slug + '_verbreitung.jpg';
  var o = '/baumportraets/images/' + slug + '_oekogramm.jpg';
  var noImg = bpt('noImage');
  return '<div class="bp-images-grid">'
    + '<div class="bp-img-tile"><p class="bp-img-label">' + bpt('imgVerbreitung') + '</p>'
    + '<img src="' + v + '" alt="' + bpt('imgVerbreitung') + '" loading="lazy" onerror="this.parentElement.innerHTML=\'<div class=bp-img-missing>' + noImg + '</div>\'"></div>'
    + '<div class="bp-img-tile bp-oeko-panel"><p class="bp-img-label">' + bpt('imgOekogramm') + bpEsc(oekoLabel) + '</p>'
    + '<img src="' + o + '" alt="' + bpt('imgOekogramm') + '" loading="lazy" onerror="this.parentElement.innerHTML=\'<div class=bp-img-missing>' + noImg + '</div>\'">'
    + '<div class="bp-oeko-legend"><strong>' + bpt('oekoLegend') + '</strong>'
    + '<div class="bp-oeko-items">'
    + '<div class="bp-oeko-item"><span class="bp-oeko-sw bp-oeko-sw--fund"></span>' + bpt('oekoFund') + '</div>'
    + '<div class="bp-oeko-item"><span class="bp-oeko-sw bp-oeko-sw--dom"></span><em>' + bpt('oekoDom') + '</em></div>'
    + '<div class="bp-oeko-item"><span class="bp-oeko-sw bp-oeko-sw--beigem"></span><em>' + bpt('oekoBeigem') + '</em></div>'
    + '<div class="bp-oeko-item"><span class="bp-oeko-sw bp-oeko-sw--verein"></span><em>' + bpt('oekoVerein') + '</em></div>'
    + '</div></div></div></div>';
}

/* ── Morphology image tiles ──────────────────────────────── */
function morphGrid(slug) {
  var types = [
    {key:'borke',        tKey:'morphBorke'},
    {key:'knospe',       tKey:'morphKnospe'},
    {key:'blatt',        tKey:'morphBlatt'},
    {key:'bluetenstand', tKey:'morphBluete'},
    {key:'frucht',       tKey:'morphFrucht'},
  ];
  var items = types.map(function(t) {
    var src = '/baumportraets/images/' + slug + '_' + t.key + '.jpg';
    return '<div class="bp-morph-tile">'
      + '<p class="bp-img-label">' + bpt(t.tKey) + '</p>'
      + '<img src="' + src + '" alt="' + bpt(t.tKey) + '" loading="lazy" onerror="this.parentElement.style.display=\'none\'">'
      + '</div>';
  }).join('');
  return '<div class="bp-morph-grid">' + items + '</div>';
}

/* ── Accordion helpers ───────────────────────────────────── */
function acc(icon, label, content) {
  return '<details><summary><span class="bp-sum-left"><span>' + icon + '</span> ' + label
    + '</span><span class="bp-chevron" aria-hidden="true">\u203a</span></summary>'
    + '<div class="bp-acc-body">' + content + '</div></details>';
}
function sub(title, html) {
  return '<div class="bp-subsection"><div class="bp-sub-title">' + title + '</div>' + html + '</div>';
}

/* ── Description (language-aware) ───────────────────────── */
function getBeschreibung(sp) {
  if (bpLang === 'de') return sp.beschreibung;
  var trans = BESCHREIBUNG_TRANSLATIONS[sp.latin];
  if (trans && trans[bpLang]) return trans[bpLang];
  return sp.beschreibung;
}

/* ── Main render ─────────────────────────────────────────── */
function renderPortrait(sp) {
  var oekoLabel = sp.oekogramm_label ? ' (' + translateValue(sp.oekogramm_label) + ')' : '';

  var ueberblick = sub(bpt('subArteOeko'),
    imgBlock(sp.slug, oekoLabel) + '<br>' + traitsViz(sp)
  );

  var morphologie = [
    morphGrid(sp.slug),
    sub(bpt('subWachstum'),     kvTable(sp.wachstum_stamm)),
    sub(bpt('subWinterzweig'),  kvTable(sp.winterzweig)),
    sub(bpt('subBlatt'),        kvTable(sp.blatt)),
    sub(bpt('subBlueteFrucht'), kvTable(sp.bluete_frucht)),
  ].join('');

  var oekologie = [
    sub(bpt('subGrundlegendes'),  kvTable(sp.grundlegendes)),
    sub(bpt('subVerbreitung'),    kvTable(sp.verbreitung)),
    sub(bpt('subFortpflanzung'),  kvTable(sp.fortpflanzung)),
    sub(bpt('subArtbeziehungen'), kvTable(sp.artbeziehungen)),
  ].join('');

  return '<div class="bp-p-header">'
    + '<h2 class="bp-p-name">' + bpEsc(getLangName(sp)) + '</h2>'
    + '<div class="bp-p-latin">' + bpEsc(sp.latin) + '</div>'
    + '</div>'
    + '<div class="bp-p-desc">' + bpEsc(getBeschreibung(sp)) + '</div>'
    + '<div class="bp-accordion">'
    + acc('\uD83D\uDCCB', bpt('accUeberblick'),  ueberblick)
    + acc('\uD83D\uDD2C', bpt('accTaxonomie'),   renderTaxonomie(sp.taxonomie||{}))
    + acc('\uD83C\uDF3F', bpt('accMorphologie'), morphologie)
    + acc('\uD83C\uDF0D', bpt('accOekologie'),   oekologie)
    + '</div>';
}

/* ── Apply language ──────────────────────────────────────── */
function bpApplyLanguage() {
  document.getElementById('select-label').textContent = bpt('selectLabel');
  document.getElementById('empty-msg').textContent    = bpt('emptyMsg');
  document.getElementById('lightbox-close').title     = bpt('lightboxClose');
  populateDropdown();
  if (sel.value) port.innerHTML = renderPortrait(SPECIES_DATA[sel.value]);
}

/* ── Init ────────────────────────────────────────────────── */
populateDropdown();

/* ── Species selection ───────────────────────────────────── */
sel.addEventListener('change', function() {
  var latin = sel.value;
  if (!latin) { port.innerHTML = ''; empty.style.display = ''; return; }
  port.innerHTML = renderPortrait(SPECIES_DATA[latin]);
  empty.style.display = 'none';
});

/* ── Language sync with Dendromat ────────────────────────── */
document.addEventListener('dendromat:langchange', function(e) {
  var lang = e.detail && e.detail.lang;
  if (lang && BP_UI[lang]) { bpLang = lang; bpApplyLanguage(); }
});

/* ── Lightbox ────────────────────────────────────────────── */
var lb    = document.getElementById('lightbox');
var lbImg = document.getElementById('lightbox-img');
var lbCl  = document.getElementById('lightbox-close');

function openLb(src, alt) { lbImg.src = src; lbImg.alt = alt; lb.classList.add('open'); document.body.style.overflow = 'hidden'; }
function closeLb()         { lb.classList.remove('open'); document.body.style.overflow = ''; }

lb.addEventListener('click',    function(e) { if (e.target !== lbImg) closeLb(); });
lbCl.addEventListener('click',  closeLb);
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeLb(); });
document.addEventListener('click',   function(e) { if (e.target.matches('.bp-morph-tile img, .bp-img-tile img')) openLb(e.target.src, e.target.alt); });
</script>

