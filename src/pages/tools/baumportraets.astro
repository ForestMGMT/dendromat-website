---
/**
 * tools/baumportraets.astro — Baumarten­porträts tool page.
 *
 * Integrates ETH Zürich dendrological species portraits into Dendromat.
 * Language syncs with Dendromat's global switcher via dendromat:langchange event.
 *
 * Data (served as classic scripts from /public/baumportraets/):
 *   species_data.js          → const SPECIES_DATA
 *   translations_data.js     → const DATA_TRANSLATIONS
 *   beschreibung_translations.js → const BESCHREIBUNG_TRANSLATIONS
 *
 * Images: /public/baumportraets/images/[slug]_[type].jpg
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Baumarten­porträts – Dendromat"
  description="Detaillierte Porträts heimischer Baumarten mit Bestimmungs­hilfen, Standort­ansprüchen und forstlichem Wissen."
>
  <NavBar />

  <main class="tool-page">

    <!-- ── Tool hero header ───────────────────────────────── -->
    <div class="tool-page__hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Dendromat</a>
          <span aria-hidden="true">›</span>
          <span data-i18n="nav.tools">Werkzeuge</span>
          <span aria-hidden="true">›</span>
          <span data-i18n="nav.baumportraets">Baumarten­porträts</span>
        </nav>
        <h1 class="tool-page__title" data-i18n="tools.baumportraets.title">
          Baumarten­porträts
        </h1>
        <p class="tool-page__lead" data-i18n="tools.baumportraets.desc">
          Detaillierte Porträts heimischer Baumarten mit Bestimmungs­hilfen, Standort­ansprüchen und forstlichem Wissen.
        </p>
      </div>
    </div>

    <!-- ── Attribution disclaimer ─────────────────────────── -->
    <div class="attribution">
      <div class="container">
        <div class="attribution__inner">
          <span class="attribution__icon" aria-hidden="true">📚</span>
          <div class="attribution__text">
            <strong>Datenquelle:</strong> Alle Inhalte und Bilder stammen aus den folgenden Publikationen:<br>
            <span class="attribution__ref">
              Rudow, A., 2024: <em>Dendrologie Artenportraits. Morphologische und ökologische Eigenschaften der Gehölzarten Mitteleuropas.</em>
              <a href="https://www.dendro.ethz.ch" target="_blank" rel="noopener">www.dendro.ethz.ch</a>.
              Hrsg. Dendrologie und Vegetationskunde, ETH Zürich.
            </span>
            <span class="attribution__ref">
              Rudow, A., Könz, G., Manohar, N., Glanzmann, L., Zürcher, S., 2024: <em>Kurzportraits Baumarten.</em>
              <a href="https://www.gebirgswald.ch" target="_blank" rel="noopener">www.gebirgswald.ch</a> /
              <a href="https://www.dendro.ethz.ch" target="_blank" rel="noopener">www.dendro.ethz.ch</a>.
              Hrsg. Fachstelle Gebirgswaldpflege GWP Maienfeld und Dendrologie und Vegetationskunde ETH Zürich.
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Species selector + portrait ───────────────────── -->
    <div class="tool-body">
      <div class="container">

        <div class="select-wrap">
          <label id="select-label" for="sp-sel">Baumart auswählen</label>
          <select id="sp-sel">
            <option value="">– Bitte Baumart wählen –</option>
          </select>
        </div>

        <div id="bp-empty" class="bp-empty">
          <div class="bp-empty__icon" aria-hidden="true">🌲</div>
          <p id="empty-msg">Wähle eine Baumart aus dem Dropdown-Menü.</p>
        </div>

        <div id="portrait"></div>

      </div>
    </div>

  </main>

  <!-- Lightbox -->
  <div id="lightbox" role="dialog" aria-modal="true" aria-label="Bildvergrösserung">
    <span id="lightbox-close" title="Schliessen">✕</span>
    <img id="lightbox-img" src="" alt="">
  </div>

  <Footer />
</BaseLayout>

<!-- Load data as classic scripts (must be before main is:inline script) -->
<script src="/baumportraets/species_data.js" is:inline></script>
<script src="/baumportraets/translations_data.js" is:inline></script>
<script src="/baumportraets/beschreibung_translations.js" is:inline></script>

<script is:inline>
