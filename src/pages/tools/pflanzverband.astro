---
/**
 * tools/pflanzverband.astro — Pflanzverband-Rechner
 *
 * Calculates number of plants needed for:
 *   - Flächige Pflanzung: Vierecksverband (a²) or Dreiecksverband (a²·√3/2)
 *   - Trupppflanzung: groups in triangular arrangement (d²·√3/2 per group)
 *
 * Language syncs with Dendromat via dendromat:langchange event.
 * Renders a canvas preview of the planting pattern.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Pflanzverband-Rechner – Dendromat"
  description="Berechne die Anzahl benötigter Pflanzen für Flächen- und Trupppflanzungen."
>
  <NavBar />

  <main class="tool-page">

    <!-- ── Hero ─────────────────────────────────────────────── -->
    <div class="tool-page__hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Dendromat</a>
          <span aria-hidden="true">›</span>
          <span data-i18n="nav.tools">Werkzeuge</span>
          <span aria-hidden="true">›</span>
          <span data-i18n="nav.pflanzverband">Pflanzverband-Rechner</span>
        </nav>
        <h1 class="tool-page__title" data-i18n="tools.pflanzverband.title">
          Pflanzverband-Rechner
        </h1>
        <p class="tool-page__lead" data-i18n="tools.pflanzverband.desc">
          Berechne die Anzahl benötigter Pflanzen für Flächen- und Trupppflanzungen – mit Vorschau des Pflanzschemas.
        </p>
      </div>
    </div>

    <!-- ── Tool body ─────────────────────────────────────────── -->
    <div class="tool-body">
      <div class="container">
        <div class="pv-layout">

          <!-- ── Form ──────────────────────────────────────── -->
          <div class="pv-form">

            <!-- Step 1: Type -->
            <div class="pv-field">
              <div class="pv-field__label" id="pv-label-type">Pflanzverband</div>
              <div class="pv-toggle" role="group" aria-labelledby="pv-label-type">
                <button class="pv-toggle__btn pv-toggle__btn--active" id="btn-flaechig">
                  🌳 Flächige Pflanzung
                </button>
                <button class="pv-toggle__btn" id="btn-trupp">
                  🌿 Trupppflanzung
                </button>
              </div>
            </div>

            <!-- Step 2: Plot size -->
            <div class="pv-field">
              <label class="pv-field__label" id="pv-label-area" for="pv-area">Fläche</label>
              <div class="pv-input-group">
                <input type="number" id="pv-area" class="pv-input" min="1" step="100" value="1000">
                <span class="pv-input-unit">m²</span>
                <span class="pv-input-hint" id="pv-area-ha"></span>
              </div>
            </div>

            <!-- Step 3a: Flächige params -->
            <div id="pv-params-flaechig">
              <div class="pv-field-row">
                <div class="pv-field">
                  <label class="pv-field__label" id="pv-label-spacing" for="pv-spacing">Pflanzabstand</label>
                  <div class="pv-input-group">
                    <input type="number" id="pv-spacing" class="pv-input" min="0.3" max="20" step="0.1" value="2.0">
                    <span class="pv-input-unit">m</span>
                  </div>
                </div>
                <div class="pv-field">
                  <label class="pv-field__label" id="pv-label-pattern" for="pv-pattern">Verband</label>
                  <select id="pv-pattern" class="pv-select">
                    <option value="dreieck">Dreiecksverband ▲</option>
                    <option value="viereck">Vierecksverband ▪</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Step 3b: Trupp params -->
            <div id="pv-params-trupp" style="display:none">
              <div class="pv-field-row">
                <div class="pv-field">
                  <label class="pv-field__label" id="pv-label-plants-per-trupp" for="pv-plants-per-trupp">Pflanzen pro Trupp</label>
                  <div class="pv-input-group">
                    <input type="number" id="pv-plants-per-trupp" class="pv-input" min="1" max="25" step="1" value="5">
                    <span class="pv-input-unit" id="pv-unit-pcs">Stk.</span>
                  </div>
                </div>
                <div class="pv-field">
                  <label class="pv-field__label" id="pv-label-trupp-spacing" for="pv-trupp-spacing">Abstand zwischen Trupps</label>
                  <div class="pv-input-group">
                    <input type="number" id="pv-trupp-spacing" class="pv-input" min="1" max="200" step="0.5" value="10">
                    <span class="pv-input-unit">m</span>
                  </div>
                </div>
              </div>
            </div>

          </div><!-- end pv-form -->

          <!-- ── Results ───────────────────────────────────── -->
          <div class="pv-results">
            <div class="pv-result-card">
              <div class="pv-result-num" id="pv-total">—</div>
              <div class="pv-result-label" id="pv-label-total">Pflanzen total</div>
            </div>
            <div class="pv-result-card">
              <div class="pv-result-num" id="pv-per-ha">—</div>
              <div class="pv-result-label" id="pv-label-per-ha">Pflanzen / ha</div>
            </div>
            <div class="pv-result-card" id="pv-card-trupps" style="display:none">
              <div class="pv-result-num" id="pv-num-trupps">—</div>
              <div class="pv-result-label" id="pv-label-trupps">Trupps total</div>
            </div>
          </div>

          <!-- ── Canvas preview ────────────────────────────── -->
          <div class="pv-preview">
            <div class="pv-preview__label" id="pv-label-preview">Vorschau Pflanzschema</div>
            <canvas id="pv-canvas" width="640" height="340"></canvas>
          </div>

          <!-- ── Formula note ──────────────────────────────── -->
          <div class="pv-formula-note">
            <strong id="pv-label-formula">Formel:</strong>
            <span id="pv-formula-text"></span>
          </div>

        </div><!-- end pv-layout -->
      </div>
    </div>

  </main>

  <Footer />
</BaseLayout>

<script is:inline>
/* ══════════════════════════════════════════════════════════
   PFLANZVERBAND-RECHNER
   Language syncs with Dendromat via dendromat:langchange.
══════════════════════════════════════════════════════════ */

/* ── UI strings ─────────────────────────────────────────── */
var PV_UI = {
  de: {
    typeLabel:          'Pflanzverband',
    btnFlaechig:        '🌳 Flächige Pflanzung',
    btnTrupp:           '🌿 Trupppflanzung',
    areaLabel:          'Fläche',
    spacingLabel:       'Pflanzabstand',
    patternLabel:       'Verband',
    optDreieck:         'Dreiecksverband ▲',
    optViereck:         'Vierecksverband ▪',
    plantsPerTruppLabel:'Pflanzen pro Trupp',
    truppSpacingLabel:  'Abstand zwischen Trupps',
    unitPcs:            'Stk.',
    resultTotal:        'Pflanzen total',
    resultPerHa:        'Pflanzen / ha',
    resultTrupps:       'Trupps total',
    previewLabel:       'Vorschau Pflanzschema',
    formulaLabel:       'Formel:',
    fViereck:           'Vierecksverband: Fläche/Pflanze = a² =',
    fDreieck:           'Dreiecksverband: Fläche/Pflanze = a²·(√3/2) =',
    fTrupp:             'Dreiecksverband Trupps: Fläche/Trupp = d²·(√3/2) =',
    fTruppMid:          'Trupps ×',
    fTruppEnd:          'Pflanzen',
  },
  fr: {
    typeLabel:          'Mode de plantation',
    btnFlaechig:        '🌳 Plantation en plein',
    btnTrupp:           '🌿 Plantation en cellules',
    areaLabel:          'Surface',
    spacingLabel:       'Espacement',
    patternLabel:       'Disposition',
    optDreieck:         'Disposition triangulaire ▲',
    optViereck:         'Disposition en carré ▪',
    plantsPerTruppLabel:'Plants par cellule',
    truppSpacingLabel:  'Distance entre cellules',
    unitPcs:            'pcs',
    resultTotal:        'Plants au total',
    resultPerHa:        'Plants / ha',
    resultTrupps:       '# Cellules total',
    previewLabel:       'Aperçu du schéma',
    formulaLabel:       'Formule :',
    fViereck:           'Carré : Surface/plant = a² =',
    fDreieck:           'Triangle : Surface/plant = a²·(√3/2) =',
    fTrupp:             'Triangle cellules : Surface/cellules = d²·(√3/2) =',
    fTruppMid:          'cellules ×',
    fTruppEnd:          'plants',
  },
  it: {
    typeLabel:          'Schema di impianto',
    btnFlaechig:        '🌳 Impianto a pieno campo',
    btnTrupp:           '🌿 Impianto a gruppi',
    areaLabel:          'Superficie',
    spacingLabel:       'Spaziatura',
    patternLabel:       'Disposizione',
    optDreieck:         'Disposizione triangolare ▲',
    optViereck:         'Disposizione quadrata ▪',
    plantsPerTruppLabel:'Piante per gruppo',
    truppSpacingLabel:  'Distanza tra gruppi',
    unitPcs:            'pz.',
    resultTotal:        'Piante totali',
    resultPerHa:        'Piante / ha',
    resultTrupps:       'Gruppi totali',
    previewLabel:       'Anteprima schema',
    formulaLabel:       'Formula:',
    fViereck:           'Quadrato: Superficie/pianta = a² =',
    fDreieck:           'Triangolare: Superficie/pianta = a²·(√3/2) =',
    fTrupp:             'Triangolare gruppi: Superficie/gruppo = d²·(√3/2) =',
    fTruppMid:          'gruppi ×',
    fTruppEnd:          'piante',
  },
  en: {
    typeLabel:          'Planting type',
    btnFlaechig:        '🌳 Area planting',
    btnTrupp:           '🌿 Group planting',
    areaLabel:          'Area',
    spacingLabel:       'Spacing',
    patternLabel:       'Pattern',
    optDreieck:         'Triangular ▲',
    optViereck:         'Square ▪',
    plantsPerTruppLabel:'Plants per group',
    truppSpacingLabel:  'Distance between groups',
    unitPcs:            'pcs',
    resultTotal:        'Total plants',
    resultPerHa:        'Plants / ha',
    resultTrupps:       'Total groups',
    previewLabel:       'Planting pattern preview',
    formulaLabel:       'Formula:',
    fViereck:           'Square: Area/plant = a² =',
    fDreieck:           'Triangle: Area/plant = a²·(√3/2) =',
    fTrupp:             'Triangle groups: Area/group = d²·(√3/2) =',
    fTruppMid:          'groups ×',
    fTruppEnd:          'plants',
  },
};

/* ── Language state ──────────────────────────────────────── */
var pvLang = localStorage.getItem('dendromat-lang') || 'de';
if (!PV_UI[pvLang]) pvLang = 'de';

function pvt(key) {
  return (PV_UI[pvLang] || PV_UI.de)[key] || PV_UI.de[key] || key;
}

/* ── Apply language to all static labels ─────────────────── */
function pvApplyLanguage() {
  document.getElementById('pv-label-type').textContent            = pvt('typeLabel');
  document.getElementById('btn-flaechig').textContent             = pvt('btnFlaechig');
  document.getElementById('btn-trupp').textContent                = pvt('btnTrupp');
  document.getElementById('pv-label-area').textContent            = pvt('areaLabel');
  document.getElementById('pv-label-spacing').textContent         = pvt('spacingLabel');
  document.getElementById('pv-label-pattern').textContent         = pvt('patternLabel');
  document.getElementById('pv-label-plants-per-trupp').textContent= pvt('plantsPerTruppLabel');
  document.getElementById('pv-label-trupp-spacing').textContent   = pvt('truppSpacingLabel');
  document.getElementById('pv-unit-pcs').textContent              = pvt('unitPcs');
  document.getElementById('pv-label-total').textContent           = pvt('resultTotal');
  document.getElementById('pv-label-per-ha').textContent          = pvt('resultPerHa');
  document.getElementById('pv-label-trupps').textContent          = pvt('resultTrupps');
  document.getElementById('pv-label-preview').textContent         = pvt('previewLabel');
  document.getElementById('pv-label-formula').textContent         = pvt('formulaLabel');

  // Update select options (preserve current value)
  var sel = document.getElementById('pv-pattern');
  var cur = sel.value;
  sel.options[0].text = pvt('optDreieck');
  sel.options[1].text = pvt('optViereck');
  sel.value = cur;

  pvUpdate();
}

/* ── Type toggle ─────────────────────────────────────────── */
var pvType = 'flaechig';

document.getElementById('btn-flaechig').addEventListener('click', function () {
  pvType = 'flaechig';
  document.getElementById('btn-flaechig').classList.add('pv-toggle__btn--active');
  document.getElementById('btn-trupp').classList.remove('pv-toggle__btn--active');
  document.getElementById('pv-params-flaechig').style.display = '';
  document.getElementById('pv-params-trupp').style.display = 'none';
  document.getElementById('pv-card-trupps').style.display = 'none';
  pvUpdate();
});

document.getElementById('btn-trupp').addEventListener('click', function () {
  pvType = 'trupp';
  document.getElementById('btn-trupp').classList.add('pv-toggle__btn--active');
  document.getElementById('btn-flaechig').classList.remove('pv-toggle__btn--active');
  document.getElementById('pv-params-flaechig').style.display = 'none';
  document.getElementById('pv-params-trupp').style.display = '';
  pvUpdate();
});

/* ── Input listeners ─────────────────────────────────────── */
['pv-area', 'pv-spacing', 'pv-plants-per-trupp', 'pv-trupp-spacing'].forEach(function (id) {
  document.getElementById(id).addEventListener('input', pvUpdate);
});
document.getElementById('pv-pattern').addEventListener('change', pvUpdate);

// Hard-clamp plants-per-trupp to 1–25 while typing
document.getElementById('pv-plants-per-trupp').addEventListener('input', function () {
  var v = parseInt(this.value);
  if (v > 25) this.value = 25;
  if (v < 1)  this.value = 1;
});

/* ── Calculate & update ──────────────────────────────────── */
function pvUpdate() {
  var area = parseFloat(document.getElementById('pv-area').value) || 0;

  // ha hint
  var haEl = document.getElementById('pv-area-ha');
  haEl.textContent = area > 0
    ? '≈ ' + (area / 10000).toLocaleString('de-CH', { maximumFractionDigits: 4 }) + ' ha'
    : '';

  if (area <= 0) { pvClearResults(); pvDraw(); return; }

  if (pvType === 'flaechig') {
    var a   = parseFloat(document.getElementById('pv-spacing').value) || 0;
    var pat = document.getElementById('pv-pattern').value;
    if (a <= 0) { pvClearResults(); pvDraw(); return; }

    var areaPerPlant = pat === 'viereck' ? a * a : a * a * Math.sqrt(3) / 2;
    var total = Math.ceil(area / areaPerPlant);
    var perHa = Math.round(10000 / areaPerPlant);

    document.getElementById('pv-total').textContent  = total.toLocaleString('de-CH');
    document.getElementById('pv-per-ha').textContent = perHa.toLocaleString('de-CH');
    document.getElementById('pv-card-trupps').style.display = 'none';

    document.getElementById('pv-formula-text').textContent =
      (pat === 'viereck' ? pvt('fViereck') : pvt('fDreieck'))
      + ' ' + areaPerPlant.toFixed(2) + ' m²';

  } else {
    var d = parseFloat(document.getElementById('pv-trupp-spacing').value) || 0;
    var n = parseInt(document.getElementById('pv-plants-per-trupp').value) || 0;
    if (d <= 0 || n <= 0) { pvClearResults(); pvDraw(); return; }

    var areaPerTrupp = d * d * Math.sqrt(3) / 2;
    var numTrupps    = Math.ceil(area / areaPerTrupp);
    var total        = numTrupps * n;
    var perHa        = Math.round(n * 10000 / areaPerTrupp);

    document.getElementById('pv-total').textContent      = total.toLocaleString('de-CH');
    document.getElementById('pv-per-ha').textContent     = perHa.toLocaleString('de-CH');
    document.getElementById('pv-num-trupps').textContent = numTrupps.toLocaleString('de-CH');
    document.getElementById('pv-card-trupps').style.display = '';

    document.getElementById('pv-formula-text').textContent =
      pvt('fTrupp') + ' ' + areaPerTrupp.toFixed(1) + ' m²  →  '
      + numTrupps + ' ' + pvt('fTruppMid') + ' ' + n + ' ' + pvt('fTruppEnd');
  }

  pvDraw();
}

function pvClearResults() {
  ['pv-total', 'pv-per-ha', 'pv-num-trupps'].forEach(function (id) {
    document.getElementById(id).textContent = '—';
  });
  document.getElementById('pv-formula-text').textContent = '';
}

/* ── Canvas ──────────────────────────────────────────────── */
function pvDraw() {
  var canvas = document.getElementById('pv-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var W = canvas.width;
  var H = canvas.height;

  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#f0f7ee';
  ctx.fillRect(0, 0, W, H);

  if (pvType === 'flaechig') {
    var a    = parseFloat(document.getElementById('pv-spacing').value) || 2;
    var pat  = document.getElementById('pv-pattern').value;
    var rowH = pat === 'dreieck' ? a * Math.sqrt(3) / 2 : a;
    var scale = W / (9 * a);
    var cols  = Math.ceil(W / (a * scale)) + 2;
    var rows  = Math.ceil(H / (rowH * scale)) + 2;
    var ox    = (W - (cols - 1) * a * scale) / 2;
    var oy    = (H - (rows - 1) * rowH * scale) / 2;

    for (var r = 0; r < rows; r++) {
      for (var c = 0; c < cols; c++) {
        var xOff = (pat === 'dreieck' && r % 2 === 1) ? a * scale / 2 : 0;
        pvDot(ctx, ox + c * a * scale + xOff, oy + r * rowH * scale, 5, '#2a5c28');
      }
    }

  } else {
    var d     = parseFloat(document.getElementById('pv-trupp-spacing').value) || 10;
    var n     = parseInt(document.getElementById('pv-plants-per-trupp').value) || 5;
    var rowHt = d * Math.sqrt(3) / 2;
    var scale = W / (5 * d);
    var cols  = Math.ceil(W / (d * scale)) + 2;
    var rows  = Math.ceil(H / (rowHt * scale)) + 2;
    var ox    = (W - (cols - 1) * d * scale) / 2;
    var oy    = (H - (rows - 1) * rowHt * scale) / 2;

    for (var r = 0; r < rows; r++) {
      for (var c = 0; c < cols; c++) {
        var xOff = (r % 2 === 1) ? d * scale / 2 : 0;
        var cx = ox + c * d * scale + xOff;
        var cy = oy + r * rowHt * scale;
        var td = pvGetTruppData(Math.min(n, 19), d, scale);
        // boundary circle = 2.5 m radius in real world
        var boundaryR = 2.5 * Math.min(1.0, (d * 0.45) / 2.5) * scale;
        ctx.beginPath();
        ctx.arc(cx, cy, boundaryR, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(46,104,48,0.07)';
        ctx.fill();
        ctx.strokeStyle = 'rgba(46,104,48,0.18)';
        ctx.lineWidth = 1;
        ctx.stroke();
        td.positions.forEach(function (p) {
          pvDot(ctx, cx + p.x, cy + p.y, 3, '#2a5c28');
        });
      }
    }
  }

  ctx.strokeStyle = 'rgba(46,104,48,0.25)';
  ctx.lineWidth   = 1;
  ctx.strokeRect(0.5, 0.5, W - 1, H - 1);
}

function pvDot(ctx, x, y, r, color) {
  ctx.beginPath();
  ctx.arc(x, y, r, 0, Math.PI * 2);
  ctx.fillStyle = color;
  ctx.fill();
}

/* ── Trupp plant positions — 3 rings max, real-world scaled ─ */
function pvGetTruppData(n, d_m, scale) {
  // Ring radii in real-world metres:
  //   ring1 = 1.25 m radius (2.5 m diameter)
  //   ring2 = 2.50 m radius (5.0 m diameter) ← defines trupp footprint
  //   ring3 = 3.75 m radius (only used for display n > 19, stays within cap)
  var rM = [1.25, 2.5, 3.75];
  // Scale down only when d is very small (outer ring must fit within 45 % of d)
  var sf = Math.min(1.0, (d_m * 0.45) / rM[1]);
  var r  = [rM[0] * sf * scale, rM[1] * sf * scale, rM[2] * sf * scale];

  var pos = [];
  var outerR = r[0];

  function ring(count, radius) {
    for (var i = 0; i < count; i++) {
      var a = (2 * Math.PI * i / count) - Math.PI / 2;
      pos.push({ x: Math.cos(a) * radius, y: Math.sin(a) * radius });
    }
  }

  if (n === 1) {
    // Centre only
    pos.push({ x: 0, y: 0 });
    outerR = r[0] * 0.5;
  } else if (n <= 7) {
    // Centre + Ring 1 (n-1)
    pos.push({ x: 0, y: 0 });
    ring(n - 1, r[0]);
    outerR = r[0];
  } else if (n <= 19) {
    // Centre + Ring 1 (6) + Ring 2 (n-7)
    pos.push({ x: 0, y: 0 });
    ring(6,     r[0]);
    ring(n - 7, r[1]);
    outerR = r[1];
  } else {
    // Centre + Ring 1 (6) + Ring 2 (12) + Ring 3 (n-19), max n = 25
    pos.push({ x: 0, y: 0 });
    ring(6,      r[0]);
    ring(12,     r[1]);
    ring(n - 19, r[2]);
    outerR = r[2];
  }

  return { positions: pos, outerR: outerR };
}

/* ── Language sync ───────────────────────────────────────── */
document.addEventListener('dendromat:langchange', function (e) {
  var lang = e.detail && e.detail.lang;
  if (lang && PV_UI[lang]) { pvLang = lang; pvApplyLanguage(); }
});

/* ── Init ────────────────────────────────────────────────── */
pvApplyLanguage();
</script>

<style>
  /* ── Hero ───────────────────────────────────────────────── */
  .tool-page__hero {
    background: linear-gradient(135deg, var(--clr-green-dark), var(--clr-green-mid));
    padding: var(--space-lg) 0;
    color: var(--clr-white);
  }
  .breadcrumb { display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; color: var(--clr-green-pale); margin-bottom: var(--space-sm); flex-wrap: wrap; }
  .breadcrumb a { color: var(--clr-green-light); text-decoration: none; }
  .breadcrumb a:hover { color: var(--clr-yellow); }
  .tool-page__title { font-size: clamp(1.6rem, 4vw, 2.8rem); color: var(--clr-white); margin-bottom: 0.35rem; }
  .tool-page__lead  { font-size: 1rem; color: var(--clr-green-pale); max-width: 65ch; line-height: 1.6; }

  /* ── Body ───────────────────────────────────────────────── */
  .tool-body { padding: var(--space-lg) 0 var(--space-xl); background: var(--clr-offwhite); min-height: 60vh; }
  .pv-layout { display: flex; flex-direction: column; gap: var(--space-lg); max-width: 720px; }

  /* ── Form card ──────────────────────────────────────────── */
  .pv-form {
    background: var(--clr-white);
    border: 1px solid #d8e8d8;
    border-radius: 12px;
    padding: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .pv-field__label {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--clr-green-deep);
    margin-bottom: 0.5rem;
  }
