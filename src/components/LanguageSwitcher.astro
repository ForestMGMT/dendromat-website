---
/**
 * LanguageSwitcher.astro
 *
 * Renders DE / FR / IT / EN toggle buttons.
 * Language state is stored in localStorage and applied on load.
 * All translatable elements carry a data-i18n="section.key" attribute;
 * the i18n script below walks the DOM and replaces textContent.
 */
---

<div class="lang-switcher" role="group" aria-label="Language switcher">
  <button class="lang-btn" data-lang="de" aria-pressed="true">DE</button>
  <button class="lang-btn" data-lang="fr" aria-pressed="false">FR</button>
  <button class="lang-btn" data-lang="it" aria-pressed="false">IT</button>
  <button class="lang-btn" data-lang="en" aria-pressed="false">EN</button>
</div>

<style>
  .lang-switcher {
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }

  .lang-btn {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.55rem;
    border: 1.5px solid var(--clr-green-light);
    border-radius: 4px;
    background: transparent;
    color: var(--clr-white);
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    line-height: 1;
  }

  .lang-btn:hover {
    background: var(--clr-green-light);
    color: var(--clr-green-deep);
    border-color: var(--clr-green-light);
  }

  .lang-btn[aria-pressed="true"] {
    background: var(--clr-yellow);
    color: var(--clr-green-deep);
    border-color: var(--clr-yellow);
  }
</style>

<!-- i18n engine — loaded once, runs on every page -->
<script>
import { t, defaultLang } from '../i18n/translations.js';

// -------------------------------------------------------
// Read current lang from localStorage (or default)
// -------------------------------------------------------
const storedLang = localStorage.getItem('dendromat-lang');
let currentLang = (storedLang && t[storedLang]) ? storedLang : defaultLang;

// -------------------------------------------------------
// Apply translations to all data-i18n elements
// -------------------------------------------------------
function applyTranslations(lang) {
  const strings = t[lang];
  document.querySelectorAll('[data-i18n]').forEach((el) => {
    const key = el.getAttribute('data-i18n'); // e.g. "intro.headline"
    const parts = key.split('.');
    let value = strings;
    for (const part of parts) {
      value = value?.[part];
      if (value === undefined) break;
    }
    if (typeof value === 'string') {
      el.textContent = value;
    }
  });

  // Update <html lang> for accessibility
  document.documentElement.lang = lang;

  // Update page <title> and meta description if keys exist
  const metaTitle = strings?.meta?.title;
  const metaDesc  = strings?.meta?.description;
  if (metaTitle) document.title = metaTitle;
  if (metaDesc) {
    const descEl = document.querySelector('meta[name="description"]');
    if (descEl) descEl.setAttribute('content', metaDesc);
  }
}

// -------------------------------------------------------
// Wire up buttons
// -------------------------------------------------------
function initSwitcher() {
  const buttons = document.querySelectorAll('.lang-btn');

  function setLang(lang) {
    currentLang = lang;
    localStorage.setItem('dendromat-lang', lang);
    applyTranslations(lang);

    // Update aria-pressed states
    buttons.forEach((btn) => {
      btn.setAttribute(
        'aria-pressed',
        btn.getAttribute('data-lang') === lang ? 'true' : 'false'
      );
    });
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const lang = btn.getAttribute('data-lang');
      if (lang && t[lang]) setLang(lang);
    });
  });

  // Apply on first load
  setLang(currentLang);
}

// Run after DOM is ready
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initSwitcher);
} else {
  initSwitcher();
}
</script>
